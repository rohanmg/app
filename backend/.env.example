# Example environment for the FastAPI backend.
# Copy to `backend/.env` for local dev. On Render, the blueprint sets these for you;
# only AWS_BEARER_TOKEN_BEDROCK must be pasted in the Render dashboard.

# ----- Database -----
# Local dev:  mongodb://localhost:27017
# Render:     mongodb://architecht-mongo:27017 (the self-hosted Mongo Docker pserv)
MONGO_URL=mongodb://localhost:27017
DB_NAME=architecht

# ----- CORS -----
# Comma-separated. Use "*" for dev; in prod set to your frontend origin.
CORS_ORIGINS=*

# ----- JWT -----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# ----- AWS Bedrock (Claude Sonnet 4.5 / Haiku 4.5) -----
# Generate from AWS Console → Amazon Bedrock → API Keys.
# Key must have access to the chosen model in the chosen region.
AWS_BEARER_TOKEN_BEDROCK=bedrock-api-key-REPLACE_ME
AWS_REGION=ap-southeast-2

# Sonnet 4.5 via APAC cross-region inference profile (default):
BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-5-20250929-v1:0
# Haiku 4.5 (cheaper/faster):
# BEDROCK_MODEL_ID=apac.anthropic.claude-haiku-4-5-20251022-v1:0

# Example environment for the React frontend.
# Copy to `frontend/.env` for local dev. On Render, set REACT_APP_BACKEND_URL in the dashboard.

# URL of the deployed backend. For local dev with the bundled dev server use:
#   http://localhost:8001
# For Render deployment:
#   https://architecht-backend.onrender.com
REACT_APP_BACKEND_URL=http://localhost:8001
WDS_SOCKET_PORT=443
